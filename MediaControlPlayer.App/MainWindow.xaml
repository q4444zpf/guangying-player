<Window x:Class="MediaControlPlayer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Title="光影播放器"
        MouseMove="Window_MouseMove"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部标题栏，默认隐藏，鼠标移到顶端时显示 -->
        <Border x:Name="TitleBarRoot"
                Grid.Row="0"
                Background="#66000000"
                Height="32"
                Visibility="Collapsed"
                MouseLeftButtonDown="TitleBarRoot_MouseLeftButtonDown">
            <DockPanel LastChildFill="False" Margin="8,0">
                <TextBlock Text="光影播放器"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="14"
                           DockPanel.Dock="Left" />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right">
                    <Button x:Name="StopButton"
                            Content="■"
                            Width="32"
                            Height="24"
                            Margin="4,4,0,4"
                            Click="StopButton_Click"
                            ToolTip="停止" />
                    <Button x:Name="MinimizeButton"
                            Content="—"
                            Width="32"
                            Height="24"
                            Margin="0,4,0,4"
                            Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton"
                            Content="▢"
                            Width="32"
                            Height="24"
                            Margin="4,4,0,4"
                            Click="MaximizeButton_Click" />
                    <Button x:Name="CloseButton"
                            Content="X"
                            Width="32"
                            Height="24"
                            Margin="4,4,0,4"
                            Click="CloseButton_Click" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 播放区域 -->
        <Grid Grid.Row="1">
            <!-- 视频输出区域：覆盖层必须放在 VideoView 内部，否则 airspace 导致原生窗口始终在上层 -->
            <vlc:VideoView x:Name="VideoViewControl">
                <Grid>
                    <Border x:Name="VideoOverlay"
                            Background="#01000000"
                            MouseMove="VideoOverlay_MouseMove"
                            MouseLeave="VideoOverlay_MouseLeave"
                            MouseLeftButtonUp="VideoOverlay_MouseLeftButtonUp" />
                    <Border x:Name="PlayButtonOverlay"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Width="80"
                            Height="80"
                            CornerRadius="40"
                            Background="#99000000"
                            Cursor="Hand"
                            MouseLeftButtonUp="PlayButtonOverlay_MouseLeftButtonUp">
                        <TextBlock Text="▶"
                                   FontSize="36"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0" />
                    </Border>
                </Grid>
            </vlc:VideoView>

            <!-- 图片显示层，默认隐藏，在图片+音频模式下显示 -->
            <Image x:Name="ImageOverlay"
                   Visibility="Collapsed"
                   Stretch="UniformToFill"
                   MouseMove="ImageOverlay_MouseMove"
                   MouseLeave="ImageOverlay_MouseLeave"
                   MouseLeftButtonUp="ImageOverlay_MouseLeftButtonUp"
                   Panel.ZIndex="2" />
        </Grid>

        <!-- 底部播放进度条：鼠标移入窗口且有媒体时显示 -->
        <Border x:Name="ProgressBarRoot"
                Grid.Row="2"
                Background="#66000000"
                Height="36"
                Padding="12,0"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="CurrentTimeText"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="12"
                           FontFamily="Consolas"
                           Margin="0,0,8,0"
                           Text="0:00" />
                <Slider x:Name="ProgressSlider"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Minimum="0"
                        Maximum="1"
                        Value="0"
                        IsMoveToPointEnabled="True"
                        ValueChanged="ProgressSlider_ValueChanged"
                        PreviewMouseLeftButtonDown="ProgressSlider_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="ProgressSlider_PreviewMouseLeftButtonUp" />
                <TextBlock x:Name="TotalTimeText"
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="12"
                           FontFamily="Consolas"
                           Margin="8,0,0,0"
                           Text="0:00" />
                <Slider x:Name="VolumeSlider"
                        Grid.Column="3"
                        VerticalAlignment="Center"
                        Minimum="0"
                        Maximum="100"
                        Value="100"
                        Margin="12,0,4,0"
                        ValueChanged="VolumeSlider_ValueChanged"
                        ToolTip="音量" />
                <Button x:Name="MuteButton"
                        Grid.Column="4"
                        Content="🔊"
                        Width="28"
                        Height="24"
                        Margin="4,0,0,0"
                        Click="MuteButton_Click"
                        ToolTip="静音"
                        FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</Window>
